{
  "name": "trading-journal",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "server/firebase.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server/server.js",
    "prebuild": "node -e \"fetch('https://nfs.faireconomy.media/ff_calendar_thisweek.json').then(r => r.json()).then(d => require('fs').writeFileSync('public/news.json', JSON.stringify(d))).catch(e => console.log('Skipping news prebuild fetch'))\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "express": "^5.1.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.17.0",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.11.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "tesseract.js": "^7.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.1",
    "vite": "^7.0.0"
  }
}
